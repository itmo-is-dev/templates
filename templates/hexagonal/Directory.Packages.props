    <PackageVersion Include="Itmo.Dev.Platform.Observability" Version="1.4.388" />
    <PackageVersion Include="Itmo.Dev.Platform.Persistence.Postgres" Version="1.2.388" />
    <!--#if (HttpEnabled)-->
