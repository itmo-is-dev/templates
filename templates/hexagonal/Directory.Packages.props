    <PackageVersion Include="Grpc.Tools" Version="2.80.0" />
    <!--#endif-->
    <PackageVersion Include="Itmo.Dev.Editorconfig" Version="1.0.16" />
    <!--#if (BackgroundTasksEnabled)-->
    <PackageVersion Include="Itmo.Dev.Platform.BackgroundTasks" Version="2.2.388" />
    <PackageVersion Include="Itmo.Dev.Platform.BackgroundTasks.Hangfire.Postgres" Version="2.2.388" />
    <PackageVersion Include="Itmo.Dev.Platform.BackgroundTasks.Postgres" Version="2.2.388" />
    <!--#endif-->
    <!--#if (KafkaEnabled)-->
    <!--#endif-->
    <!--#if (KafkaEnabled)-->
    <PackageVersion Include="Itmo.Dev.Platform.Kafka" Version="2.3.388" />
    <!--#endif-->
    <PackageVersion Include="Itmo.Dev.Platform.MessagePersistence" Version="3.0.388" />
