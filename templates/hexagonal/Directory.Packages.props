    <!--#endif-->
    <PackageVersion Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.7" />
    <PackageVersion Include="Microsoft.Extensions.Options.ConfigurationExtensions" Version="10.0.7" />
    <PackageVersion Include="SourceKit.Generators.Builder" Version="1.2.58" />
    <PackageVersion Include="SourceKit.Analyzers.Collections" Version="1.0.58" />
    <PackageVersion Include="SourceKit.Analyzers.Enumerable" Version="1.0.58" />
    <PackageVersion Include="SourceKit.Analyzers.MemberAccessibility" Version="1.0.58" />
    <PackageVersion Include="SourceKit.Analyzers.Nullable" Version="1.0.58" />
    <PackageVersion Include="SourceKit.Analyzers.Properties" Version="1.0.58" />
